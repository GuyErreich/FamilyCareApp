rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userFamilyId() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(userDoc)
        ? get(userDoc).data.familyId
        : null;
    }

    function isFamilyMember(familyId) {
      return isSignedIn() && userFamilyId() == familyId;
    }

    match /users/{userId} {
      // Own profile (including read-before-create on first sign-in).
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      // Family members can read each other's profiles.
      allow get: if isSignedIn()
        && resource != null
        && resource.data.familyId == userFamilyId();
    }

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if isSignedIn();
      allow update: if isFamilyMember(familyId);
    }

    match /familyMembers/{memberId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create, update, delete: if isFamilyMember(request.resource.data.familyId);
    }

    match /shifts/{shiftId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if isFamilyMember(request.resource.data.familyId);
      allow update, delete: if isFamilyMember(resource.data.familyId);
    }

    match /unavailabilities/{blockId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if isFamilyMember(request.resource.data.familyId);
      allow update, delete: if isFamilyMember(resource.data.familyId);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /settings/{docId} {
      allow read, write: if isSignedIn() && (
        docId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == docId)
      );
    }
  }
}
