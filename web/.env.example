# Hosted Supabase (recommended) — Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Local Supabase only (supabase start) — uncomment instead of hosted URL above
# VITE_SUPABASE_URL=http://127.0.0.1:54321

# Optional: Web Push (set after Edge Function secrets are configured)
VITE_VAPID_PUBLIC_KEY=
